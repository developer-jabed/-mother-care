{
  "name": "mother-care-backend",
  "version": "1.0.0",
  "description": "Mother Care Management Backend",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/app/modules/Sms/sms.worker.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/app/modules/Sms/sms.worker.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sparticuz/chromium": "^149.0.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.2",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.1",
    "http-status": "^2.1.0",
    "https-proxy-agent": "^9.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.6.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.2",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}