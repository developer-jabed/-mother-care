{
  "info": {
    "name": "Student & User API",
    "_postman_id": "b7e1a2f0-1234-4a5b-9abc-student-user-api",
    "description": "Endpoints for creating a Student (linked to existing user), creating a User+Student together, updating a Student, and listing/fetching/deleting students. Uses multipart/form-data with a JSON 'data' field plus an optional 'photo' file part.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "studentId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create Student (existing user)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students",
          "host": ["{{baseUrl}}"],
          "path": ["students"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "data",
              "type": "text",
              "value": "{\n  \"userId\": 1,\n  \"admissionNumber\": \"ADM-2026-001\",\n  \"fullName\": \"John Doe\",\n  \"gender\": \"MALE\",\n  \"dateOfBirth\": \"2010-05-14\",\n  \"isActive\": true\n}"
            },
            {
              "key": "photo",
              "type": "file",
              "src": []
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create User + Student together",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/create-with-user",
          "host": ["{{baseUrl}}"],
          "path": ["students", "create-with-user"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "data",
              "type": "text",
              "value": "{\n  \"user\": {\n    \"email\": \"jane.doe@example.com\",\n    \"password\": \"StrongPass123\"\n  },\n  \"student\": {\n    \"admissionNumber\": \"ADM-2026-002\",\n    \"fullName\": \"Jane Doe\",\n    \"gender\": \"FEMALE\",\n    \"dateOfBirth\": \"2011-08-22\",\n    \"isActive\": true\n  }\n}"
            },
            {
              "key": "photo",
              "type": "file",
              "src": []
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["students", "{{studentId}}"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "data",
              "type": "text",
              "value": "{\n  \"fullName\": \"John Updated Doe\",\n  \"isActive\": true\n}"
            },
            {
              "key": "photo",
              "type": "file",
              "src": []
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Student By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["students", "{{studentId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get All Students",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students?page=1&limit=10&search=",
          "host": ["{{baseUrl}}"],
          "path": ["students"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "search", "value": "" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Student (soft delete)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{studentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["students", "{{studentId}}"]
        }
      },
      "response": []
    }
  ]
}